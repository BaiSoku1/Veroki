local module = {}

local Minimized = false
local Window
local FloatButton
local gui, button, rotatingBg, staticIcon

function module.init(fluentWindow)
    if gui and gui.Parent then
        warn("Floating button already initialized!")
        return module
    end
    
    Window = fluentWindow
    
    local Players = game:GetService("Players")
    local player = Players.LocalPlayer
    local playerGui
    if player then
        playerGui = player:WaitForChild("PlayerGui")
    else
        warn("Player not found!")
        return module
    end
    
    -- Create ScreenGui
    gui = Instance.new("ScreenGui")
    gui.Name = "FloatingButtonGUI"
    gui.ResetOnSpawn = false
    gui.Parent = playerGui
    
    -- Create main button
    button = Instance.new("TextButton")
    button.Name = "FloatingButton"
    button.Parent = gui
    button.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    button.BackgroundTransparency = 1
    button.Position = UDim2.new(0.101969875395298, 0, 0.11044176667928696, 0)
    button.Size = UDim2.new(0, 64, 0, 42)
    button.Text = ""
    
    -- Create rotating background
    rotatingBg = Instance.new("ImageLabel")
    rotatingBg.Name = "RotatingBackground"
    rotatingBg.Parent = button
    rotatingBg.Image = "rbxassetid://132923562017802"
    rotatingBg.AnchorPoint = Vector2.new(0.5, 0.5)
    rotatingBg.BackgroundTransparency = 1
    rotatingBg.Position = UDim2.new(0.5, 0, 0.5, 0)
    rotatingBg.Size = UDim2.new(1.899999976158142, 0, 1.899999976158142, 0)
    rotatingBg.SizeConstraint = Enum.SizeConstraint.RelativeXX
    rotatingBg.ZIndex = 0
    
    -- Create static icon
    staticIcon = Instance.new("ImageLabel")
    staticIcon.Name = "StaticIcon"
    staticIcon.Parent = button
    staticIcon.Image = "rbxassetid://134006068620274"
    staticIcon.AnchorPoint = Vector2.new(0.5, 0.5)
    staticIcon.BackgroundTransparency = 1
    staticIcon.Position = UDim2.new(0.5, 0, 0.5, 0)
    staticIcon.Size = UDim2.new(0.800000011920929, 0, 1, 0)
    
    -- Add corner radius to static icon
    local iconCorner = Instance.new("UICorner")
    iconCorner.Parent = staticIcon
    iconCorner.CornerRadius = UDim.new(1, 0)
    
    FloatButton = button
    
    -- Audio IDs for click sounds
    local audioIds = {
        "rbxassetid://137566474343039",
        "rbxassetid://7127123605",
        "rbxassetid://438666542"
    }
    
    -- Rotation variables
    local baseSpeed = 45
    local currentSpeed = baseSpeed
    local boostEndTime = 0
    
    -- Drag functionality
    local dragging = false
    local dragStartPos = nil
    local dragStartInputPos = nil
    local dragConnection = nil
    local dragEndConnection = nil
    
    local UserInputService = game:GetService("UserInputService")
    
    local function onDrag(input)
        if not dragging then return end
        
        local delta = input.Position - dragStartInputPos
        
        local newX = dragStartPos.X.Scale + (delta.X / gui.AbsoluteSize.X)
        local newY = dragStartPos.Y.Scale + (delta.Y / gui.AbsoluteSize.Y)
        
        newX = math.clamp(newX, 0, 1 - button.Size.X.Scale)
        newY = math.clamp(newY, 0, 1 - button.Size.Y.Scale)
        
        button.Position = UDim2.new(newX, 0, newY, 0)
    end
    
    local function stopDrag()
        dragging = false
        if dragConnection then
            dragConnection:Disconnect()
            dragConnection = nil
        end
        if dragEndConnection then
            dragEndConnection:Disconnect()
            dragEndConnection = nil
        end
    end
    
    local function startDrag(input)
        if dragging then
            stopDrag()
        end
        
        dragging = true
        dragStartPos = button.Position
        dragStartInputPos = input.Position
        
        dragConnection = UserInputService.InputChanged:Connect(function(input)
            if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                onDrag(input)
            end
        end)
        
        dragEndConnection = UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                stopDrag()
            end
        end)
    end
    
    button.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            startDrag(input)
        end
    end)
    
    button.MouseButton1Click:Connect(function()
        if dragging then return end
        
        local sound = Instance.new("Sound")
        sound.SoundId = audioIds[math.random(1, #audioIds)]
        sound.Volume = 1
        sound.Parent = gui
        sound:Play()
        
        sound.Ended:Connect(function()
            sound:Destroy()
        end)
        
        boostEndTime = tick() + 1.3
        
        -- Toggle minimize when clicked
        if Window then
            Window:Minimize()
            Minimized = true
        end
    end)
    
    button.TouchTap:Connect(function()
        if dragging then return end
        
        local sound = Instance.new("Sound")
        sound.SoundId = audioIds[math.random(1, #audioIds)]
        sound.Volume = 1
        sound.Parent = gui
        sound:Play()
        
        sound.Ended:Connect(function()
            sound:Destroy()
        end)
        
        boostEndTime = tick() + 1.3
        
        -- Toggle minimize when tapped
        if Window then
            Window:Minimize()
            Minimized = true
        end
    end)
    
    -- Rotation animation
    game:GetService("RunService").RenderStepped:Connect(function(dt)
        if tick() < boostEndTime then
            currentSpeed = 360
        else
            currentSpeed = baseSpeed
        end
        
        rotatingBg.Rotation = rotatingBg.Rotation + (currentSpeed * dt)
    end)
    
    if Window then
        Window.MinimizeToggle = function()
            if Window then
                Window:Minimize()
                Minimized = true
                return true
            end
            return false
        end
    end
    
    print("Floating button initialized successfully!")
    return module
end

function module.destroy()
    if gui then
        gui:Destroy()
        gui = nil
    end
    button = nil
    rotatingBg = nil
    staticIcon = nil
    FloatButton = nil
    print("Floating button destroyed")
    return true
end

function module.getButton()
    return button
end

function module.getGUI()
    return gui
end

function module.isMinimized()
    return Minimized
end

function module.toggleMinimize()
    if Window then
        Window:Minimize()
        Minimized = true
        return true
    end
    return false
end

function module.setWindowPosition(x, y)
    if button then
        button.Position = UDim2.new(x, 0, y, 0)
        return true
    end
    return false
end

function module.getWindowPosition()
    if button then
        return button.Position
    end
    return nil
end

return module
